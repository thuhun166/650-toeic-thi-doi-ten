{
  "project_name": "DistributedTokenRing",
  "project_description": "Distributed Token Ring System with 6 Servers and Lamport Clock",
  "version": "1.0",
  "created_date": "2026-03-21",
  "total_nodes": 6,
  "deployment_phases": {
    "phase1_setup": {
      "name": "Main Repo Setup",
      "owner": "Project Manager",
      "duration": "1 hour",
      "steps": [
        "Create main GitHub repository",
        "Push source code to main repo",
        "Create DEPLOYMENT_CONFIG.json",
        "Create ARCHITECTURE.md",
        "Create commit conventions documentation"
      ]
    },
    "phase2_local_setup": {
      "name": "Local Development Setup",
      "owner": "Each Team Member",
      "duration": "1.5 hours per person",
      "steps": [
        "Fork main repository",
        "Clone forked repo to local machine",
        "Create config_NODE_X.properties",
        "Setup MySQL local (6 databases)",
        "Compile code successfully",
        "Test run Node 1 + Client locally"
      ]
    },
    "phase3_railway_deploy": {
      "name": "Railway Deployment",
      "owner": "Each Team Member",
      "duration": "2 hours per person",
      "steps": [
        "Create Railway account",
        "Create Railway project from forked repo",
        "Add MySQL plugin",
        "Configure environment variables",
        "Deploy to Railway",
        "Collect Railway URL"
      ]
    },
    "phase4_finalization": {
      "name": "System Integration",
      "owner": "Project Manager",
      "duration": "30 minutes",
      "steps": [
        "Collect all 6 Railway URLs",
        "Create PEERS variable string",
        "Update PEERS in all 6 Railway projects",
        "Wait for all redeploys to complete",
        "Verify inter-node connectivity"
      ]
    },
    "phase5_testing": {
      "name": "End-to-End Testing",
      "owner": "All Team Members",
      "duration": "1 hour",
      "steps": [
        "Run universal client",
        "Send INSERT request to Node 1",
        "Monitor token passing through 6 nodes",
        "Verify data persistence in each database",
        "Test DELETE and QUERY operations",
        "Document test results"
      ]
    }
  },
